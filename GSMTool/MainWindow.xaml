<Window x:Class="GSMTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Web Scraper Tool (GSM)"
        MinHeight="480" MinWidth="700"
        Height="620" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Resources>

        <!-- ══ Primary Button (accent blue, system-like) ══ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#0078D7"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#A0C4E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Secondary Button (standard Windows style) ══ -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"       Value="#E1E1E1"/>
            <Setter Property="Foreground"       Value="#1A1A1A"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="BorderBrush"      Value="#ADADAD"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C8E6F8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A8D8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ URL TextBox ══ -->
        <Style x:Key="UrlBox" TargetType="TextBox">
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Background"              Value="White"/>
            <Setter Property="BorderBrush"             Value="#ADADAD"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="6,0"/>
            <Setter Property="Height"                  Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header / toolbar -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER / TOOLBAR ═══════════ -->
        <Border Grid.Row="0"
                Background="#FAFAFA"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Branding -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0">
                    <!-- Logo badge -->
                    <Border Width="30" Height="30"
                            CornerRadius="4"
                            Background="#0078D7"
                            Margin="0,0,8,0">
                        <TextBlock Text="W"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Web Scraper Tool (GSM)"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#1A1A1A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- URL Input -->
                <TextBox x:Name="UrlTextBox"
                         Grid.Column="1"
                         Style="{StaticResource UrlBox}"
                         Foreground="Gray"
                         Margin="0,0,8,0"
                         ToolTip="Enter a GSMArena device page URL"
                         GotFocus="UrlTextBox_GotFocus"
                         LostFocus="UrlTextBox_LostFocus"/>

                <!-- Fetch Button -->
                <Button x:Name="GetButton"
                        Grid.Column="2"
                        Content="Fetch Specs"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,6,0"
                        Click="LoadHtml_Click"/>

                <!-- Clear Button -->
                <Button x:Name="RefreshButton"
                        Grid.Column="3"
                        Content="Clear"
                        Style="{StaticResource SecondaryButton}"
                        Click="Refresh_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="1"
                x:Name="StatusBar"
                Background="#E8F1F8"
                BorderBrush="#B8D4E8"
                BorderThickness="0,0,0,1"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Ready - enter a GSMArena URL and click Fetch Specs."
                           FontSize="12"
                           Foreground="#005A9E"
                           VerticalAlignment="Center"/>

                <ProgressBar x:Name="LoadingBar"
                             Grid.Column="1"
                             Width="110" Height="5"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Foreground="#0078D7"
                             Background="#C8E6F8"/>
            </Grid>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"      MinWidth="200"/>   <!-- Preview -->
                <ColumnDefinition Width="5"/>                       <!-- Splitter -->
                <ColumnDefinition Width="0.55*"  MinWidth="180"/>   <!-- Output -->
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: WebView Preview ── -->
            <Border Grid.Column="0"
                    BorderBrush="#C0C0C0"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <!-- Placeholder -->
                    <Border x:Name="BrowserPlaceholder" Background="#F5F5F5">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F310;"
                                       FontSize="42"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Page preview will appear here"
                                       FontSize="13"
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Fetch a URL to get started"
                                       FontSize="11"
                                       Foreground="#B0B0B0"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <wv2:WebView2 x:Name="BrowserBox"
                                  Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- ── SPLITTER ── -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          ResizeBehavior="PreviousAndNext"
                          Background="#D0D0D0"
                          HorizontalAlignment="Center"
                          Cursor="SizeWE"/>

            <!-- ── RIGHT: Extracted Text ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Output panel header -->
                <Border Grid.Row="0"
                        Background="#F0F0F0"
                        BorderBrush="#C0C0C0"
                        BorderThickness="1,1,1,0"
                        Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Extracted Specs"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="CopyButton"
                                Grid.Column="1"
                                Content="Copy"
                                Style="{StaticResource SecondaryButton}"
                                Height="24" Padding="10,0"
                                FontSize="11"
                                Click="Copy_Click"/>
                    </Grid>
                </Border>

                <!-- Output TextBox -->
                <TextBox x:Name="OutputDataBox"
                         Grid.Row="1"
                         FontSize="12"
                         FontFamily="Consolas, Courier New"
                         Foreground="#1A1A1A"
                         Background="White"
                         BorderBrush="#C0C0C0"
                         BorderThickness="1,0,1,1"
                         Padding="8"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>
    </Grid>
</Window>